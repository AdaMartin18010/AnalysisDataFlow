import re
import sys
import json
from pathlib import Path
from collections import defaultdict

def validate_cross_references():
    """验证文档间的交叉引用"""
    print("🔗 开始验证交叉引用...")
    
    md_files = list(Path('.').rglob('*.md'))
    md_files = [f for f in md_files if not any(
        p.startswith('.') or p in ['node_modules', '__pycache__']
        for p in f.parts
    )]
    
    # 构建文件映射
    path_map = {}
    for f in md_files:
        path_map[f.name] = f
        path_map[str(f)] = f
        path_map[str(f).replace('\\', '/')] = f
    
    broken_links = []
    total_links = 0
    
    for file_path in md_files:
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()
        except:
            continue
        
        # 提取内部链接
        links = re.findall(r'\\[([^\\]]+)\\]\\(([^)]+)\\)', content)
        
        for text, url in links:
            # 跳过外部链接和锚点
            if url.startswith(('http://', 'https://', '#', 'mailto:')):
                continue
            
            total_links += 1
            
            # 解析路径
            url_clean = url.split('#')[0]
            if not url_clean:
                continue
            
            if url_clean.startswith('/'):
                target = Path('.') / url_clean.lstrip('/')
            else:
                target = file_path.parent / url_clean
            
            # 检查文件存在
            if not target.exists():
                target_md = Path(str(target) + '.md')
                if not target_md.exists():
                    broken_links.append({
                        'source': str(file_path),
                        'text': text,
                        'url': url
                    })
    
    # 保存结果
    result = {
        'total_links': total_links,
        'broken_links': len(broken_links),
        'broken_link_details': broken_links
    }
    
