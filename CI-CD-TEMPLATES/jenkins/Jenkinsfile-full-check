import re
import sys
import json
from pathlib import Path
from collections import defaultdict

def validate_theorem_registry():
    """验证定理编号的唯一性和格式"""
    print("🔍 开始验证定理注册表...")
    
    # 定理编号模式
    patterns = [
        r'(Thm|Lemma|Def|Prop|Cor)-([SKF])-(\d{2})-(\d{2})',
    ]
    
    theorems = defaultdict(list)
    errors = []
    stats = {'Thm': 0, 'Lemma': 0, 'Def': 0, 'Prop': 0, 'Cor': 0}
    
    # 扫描所有Markdown文件
    for md_file in Path('.').rglob('*.md'):
        if any(p.startswith('.') or p in ['node_modules', '__pycache__'] 
               for p in md_file.parts):
            continue
        
        try:
            with open(md_file, 'r', encoding='utf-8') as f:
                content = f.read()
        except Exception as e:
            errors.append(f"无法读取 {md_file}: {e}")
            continue
        
        for pattern in patterns:
            for match in re.finditer(pattern, content):
                theorem_id = match.group(0)
                elem_type = match.group(1)
                theorems[theorem_id].append(str(md_file))
                stats[elem_type] += 1
    
    # 检查重复
    duplicates = {k: v for k, v in theorems.items() if len(v) > 1}
    
    # 保存详细结果
    result = {
        'total_unique': len(theorems),
        'duplicates': len(duplicates),
        'by_type': stats,
        'duplicate_details': duplicates
    }
    
    with open('theorem-validation-result.json', 'w') as f:
        json.dump(result, f, indent=2)
    
    print(f"\\n📊 定理统计:")
    print(f"  唯一定理数: {len(theorems)}")
    print(f"  重复数量: {len(duplicates)}")
    print(f"\\n  按类型分布:")
    for t, c in sorted(stats.items()):
        print(f"    - {t}: {c}")
    
    if duplicates:
        print(f"\\n❌ 发现 {len(duplicates)} 个重复定理编号")
        for tid, files in list(duplicates.items())[:5]:
            print(f"  {tid}: {len(files)} 个文件")
        return False
    else:
        print(f"\\n✅ 定理注册表验证通过！")
        return True

success = validate_theorem_registry()
sys.exit(0 if success else 1)
