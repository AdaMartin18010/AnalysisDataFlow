import re
import sys
import json
from pathlib import Path
from collections import defaultdict

def check_links():
    """检查内部链接有效性"""
    print("🔗 开始检查链接有效性...")
    
    md_files = list(Path('.').rglob('*.md'))
    md_files = [f for f in md_files if not any(
        p.startswith('.') or p in ['node_modules', '__pycache__']
        for p in f.parts
    )]
    
    # 构建路径映射
    all_paths = set()
    for f in md_files:
        all_paths.add(f.name)
        all_paths.add(str(f))
        all_paths.add(str(f).replace('\\', '/'))
    
    stats = {'total': 0, 'internal': 0, 'external': 0, 'anchor': 0, 'broken': 0}
    broken = []
    
    for file_path in md_files:
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()
        except:
            continue
        
        links = re.findall(r'\\[([^\\]]+)\\]\\(([^)]+)\\)', content)
        
        for text, url in links:
            stats['total'] += 1
            
            if url.startswith(('http://', 'https://')):
                stats['external'] += 1
            elif url.startswith('#'):
                stats['anchor'] += 1
            elif url.startswith('mailto:'):
                pass
            else:
                stats['internal'] += 1
                
                # 验证内部链接
                url_clean = url.split('#')[0]
                if url_clean:
                    if url_clean.startswith('/'):
                        target = Path('.') / url_clean.lstrip('/')
                    else:
                        target = file_path.parent / url_clean
                    
                    if not target.exists():
                        target_md = Path(str(target) + '.md')
                        if not target_md.exists():
                            stats['broken'] += 1
                            broken.append({
                                'source': str(file_path),
                                'text': text,
                                'target': url
                            })
    
    # 保存结果
    result = {
        'stats': stats,
        'broken_links': broken
    }
    
    with open('link-check-result.json', 'w') as f:
        json.dump(result, f, indent=2, ensure_ascii=False)
    
    print(f"\\n📊 链接统计:")
    print(f"  总链接: {stats['total']}")
    print(f"  内部链接: {stats['internal']}")
    print(f"  外部链接: {stats['external']}")
    print(f"  无效链接: {stats['broken']}")
    
    if broken:
        print(f"\\n⚠️  发现 {len(broken)} 个无效链接")
        return False
    else:
        print(f"\\n✅ 所有链接有效！")
        return True

success = check_links()
sys.exit(0 if success else 1)
