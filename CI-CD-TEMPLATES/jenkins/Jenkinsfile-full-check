import re
import sys
import json
import subprocess
from pathlib import Path
from tempfile import NamedTemporaryFile

def validate_mermaid():
    """验证Mermaid图表语法"""
    print("📊 开始验证Mermaid图表...")
    
    md_files = list(Path('.').rglob('*.md'))
    md_files = [f for f in md_files if not any(
        p.startswith('.') or p in ['node_modules', '__pycache__']
        for p in f.parts
    )]
    
    total_diagrams = 0
    errors = []
    
    for file_path in md_files:
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()
        except:
            continue
        
        diagrams = re.findall(r'```mermaid\\s*\\n(.*?)```', content, re.DOTALL)
        
        for idx, diagram in enumerate(diagrams):
            total_diagrams += 1
            
            # 创建临时文件验证
            with NamedTemporaryFile(mode='w', suffix='.mmd', delete=False) as f:
                f.write(diagram)
                temp_path = f.name
            
            try:
                result = subprocess.run(
                    ['mmdc', '-i', temp_path, '-o', '/dev/null'],
                    capture_output=True, text=True, timeout=30
                )
                if result.returncode != 0:
                    errors.append({
                        'file': str(file_path),
                        'index': idx,
                        'error': result.stderr[:200]
                    })
            except Exception as e:
                errors.append({
                    'file': str(file_path),
                    'index': idx,
                    'error': str(e)
                })
            finally:
                Path(temp_path).unlink(missing_ok=True)
    
    # 保存结果
    result = {
        'total_diagrams': total_diagrams,
        'errors': len(errors),
        'error_details': errors
    }
    
    with open('mermaid-validation-result.json', 'w') as f:
        json.dump(result, f, indent=2, ensure_ascii=False)
    
    print(f"\\n📊 Mermaid图表统计:")
    print(f"  总图表数: {total_diagrams}")
    print(f"  语法错误: {len(errors)}")
    
    if errors:
        print(f"\\n❌ 发现 {len(errors)} 个语法错误")
        return False
    else:
        print(f"\\n✅ 所有Mermaid图表语法正确！")
        return True

success = validate_mermaid()
sys.exit(0 if success else 1)
