import re
import sys
from pathlib import Path
from collections import defaultdict

def validate_flink_theorems():
    """验证Flink文档中的定理编号"""
    flink_dir = Path('Flink')
    
    if not flink_dir.exists():
        print("Flink目录不存在，跳过检查")
        return True
    
    # Flink定理编号模式: Thm-F-XX-XX, Def-F-XX-XX, etc.
    theorem_pattern = r'(Thm|Lemma|Def|Prop|Cor)-(F)-(\d{2})-(\d{2})'
    
    theorems = defaultdict(list)
    errors = []
    
    for md_file in flink_dir.rglob('*.md'):
        if any(part.startswith('.') for part in md_file.parts):
            continue
        
        try:
            with open(md_file, 'r', encoding='utf-8') as f:
                content = f.read()
        except Exception as e:
            continue
        
        for match in re.finditer(theorem_pattern, content):
            theorem_id = match.group(0)
            theorems[theorem_id].append(str(md_file))
    
    # 检查重复
    duplicates = {k: v for k, v in theorems.items() if len(v) > 1}
    
    print(f"\n📊 Flink定理统计:")
    print(f"  唯一定理编号: {len(theorems)}")
    
    # 按类型统计
    types = defaultdict(int)
    for theorem_id in theorems:
        elem_type = theorem_id.split('-')[0]
        types[elem_type] += 1
    
    print("\n  按类型分布:")
    for t, count in sorted(types.items()):
        type_name = {'Thm': '定理', 'Lemma': '引理', 'Def': '定义', 
                     'Prop': '命题', 'Cor': '推论'}.get(t, t)
        print(f"    - {type_name}({t}): {count}")
    
    if duplicates:
        print("\n❌ 发现重复的定理编号:")
        for theorem_id, files in sorted(duplicates.items()):
            print(f"\n  {theorem_id} 出现在 {len(files)} 个文件中:")
            for f in files:
                print(f"    - {f}")
        return False
    else:
        print("\n✅ 所有Flink定理编号唯一！")
        return True

success = validate_flink_theorems()
sys.exit(0 if success else 1)
