#!/usr/bin/env groovy
/**
 * ============================================================================
 * AnalysisDataFlow Flink 专项验证 Pipeline
 * ============================================================================
 * 描述: 针对Flink模块的专项验证流水线
 * 触发条件: Flink目录变更、定时触发、手动触发
 * 功能:
 *   - Flink文档结构验证
 *   - Flink代码示例检查
 *   - Flink配置验证
 * ============================================================================
 */

// Pipeline配置参数
pipeline {
    agent {
        // 使用Docker代理环境，确保一致的构建环境
        docker {
            image 'python:3.11-slim'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }
    
    options {
        // 构建超时设置
        timeout(time: 30, unit: 'MINUTES')
        // 保留构建历史
        buildDiscarder(logRotator(numToKeepStr: '20'))
        // 禁用并发构建
        disableConcurrentBuilds()
        // 添加时间戳
        timestamps()
    }
    
    environment {
        // Python环境配置
        PYTHON_VERSION = '3.11'
        // 项目目录
        PROJECT_NAME = 'AnalysisDataFlow'
        // 通知配置（可在Jenkins凭据中配置）
        SLACK_CHANNEL = '#analysis-dataflow'
    }
    
    triggers {
        // 每周二凌晨3点自动运行
        cron('H 3 * * 2')
        // SCM轮询（如果配置Webhook则不需要）
        pollSCM('H/5 * * * *')
    }
    
    stages {
        // =====================================================================
        // Stage 1: 环境准备
        // =====================================================================
        stage('环境准备') {
            steps {
                script {
                    echo "======================================"
                    echo "🚀 AnalysisDataFlow Flink 验证流水线"
                    echo "======================================"
                    echo "构建号: ${env.BUILD_NUMBER}"
                    echo "分支: ${env.BRANCH_NAME}"
                    echo "提交: ${env.GIT_COMMIT?.take(7)}"
                }
                
                // 检出代码
                checkout scm
                
                // 安装依赖
                sh '''
                    python -m pip install --upgrade pip
                    pip install pyyaml markdown requests
                '''
                
                // 验证环境
                sh '''
                    python --version
                    pip list | grep -E "(pyyaml|markdown|requests)"
                '''
            }
        }
        
        // =====================================================================
        // Stage 2: Flink 目录结构验证
        // =====================================================================
        stage('Flink目录结构验证') {
            steps {
                script {
                    echo "::group::验证Flink目录结构"
                }
                
                sh '''
                    python3 << 'SCRIPT'
import os
import sys
from pathlib import Path

def validate_flink_structure():
    """验证Flink目录结构是否符合规范"""
    flink_dir = Path('Flink')
    
    if not flink_dir.exists():
        print("❌ Flink目录不存在")
        sys.exit(1)
    
    # 必需子目录检查
    required_dirs = [
        '01-core-concepts',
        '02-architecture',
        '03-programming-model',
        '04-state-management',
        '05-fault-tolerance',
        '06-deployment',
        '07-operations',
        '08-ecosystem'
    ]
    
    errors = []
    warnings = []
    
    for dir_name in required_dirs:
        dir_path = flink_dir / dir_name
        if not dir_path.exists():
            errors.append(f"缺少必需目录: {dir_name}")
        else:
            # 检查目录内是否有文档
            md_files = list(dir_path.rglob('*.md'))
            if len(md_files) == 0:
                warnings.append(f"目录 {dir_name} 为空（无Markdown文件）")
            else:
                print(f"✅ {dir_name}: {len(md_files)} 个文档")
    
    # 文件命名规范检查
    naming_errors = []
    for md_file in flink_dir.rglob('*.md'):
        # 检查文件名格式: 01-topic-name.md
        if not any(part.startswith('.') for part in md_file.parts):
            filename = md_file.name
            # 忽略根目录的README等文件
            if md_file.parent != flink_dir:
                if not re.match(r'^\d{2}-[a-z0-9-]+\.md$', filename):
                    naming_errors.append(f"命名不规范: {md_file}")
    
    if naming_errors:
        warnings.extend(naming_errors[:10])  # 只显示前10个
        if len(naming_errors) > 10:
            warnings.append(f"...还有 {len(naming_errors) - 10} 个命名问题")
    
    # 输出结果
    print("\n" + "="*60)
    if errors:
        print("❌ 目录结构错误:")
        for error in errors:
            print(f"  - {error}")
    
    if warnings:
        print("⚠️  警告:")
        for warning in warnings:
            print(f"  - {warning}")
    
    if not errors and not warnings:
        print("✅ Flink目录结构验证通过！")
    
    print("="*60)
    
    if errors:
        sys.exit(1)
    
    return len(errors) == 0

import re
validate_flink_structure()
