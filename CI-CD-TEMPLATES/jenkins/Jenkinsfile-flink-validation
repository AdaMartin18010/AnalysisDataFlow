import re
import sys
from pathlib import Path

def check_code_examples():
    """检查Flink代码示例的完整性和正确性"""
    flink_dir = Path('Flink')
    
    if not flink_dir.exists():
        print("Flink目录不存在，跳过检查")
        return True
    
    stats = {
        'total_files': 0,
        'files_with_code': 0,
        'java_examples': 0,
        'scala_examples': 0,
        'python_examples': 0,
        'sql_examples': 0,
        'yaml_examples': 0
    }
    
    errors = []
    
    for md_file in flink_dir.rglob('*.md'):
        if any(part.startswith('.') for part in md_file.parts):
            continue
        
        stats['total_files'] += 1
        
        try:
            with open(md_file, 'r', encoding='utf-8') as f:
                content = f.read()
        except Exception as e:
            errors.append(f"无法读取 {md_file}: {e}")
            continue
        
        # 检查代码块
        code_blocks = re.findall(r'```(\w+)?\s*\n(.*?)```', content, re.DOTALL)
        
        if code_blocks:
            stats['files_with_code'] += 1
            
            for lang, code in code_blocks:
                lang = lang or 'text'
                
                if lang in ['java']:
                    stats['java_examples'] += 1
                elif lang in ['scala', 'sc']:
                    stats['scala_examples'] += 1
                elif lang in ['python', 'py']:
                    stats['python_examples'] += 1
                elif lang in ['sql']:
                    stats['sql_examples'] += 1
                elif lang in ['yaml', 'yml']:
                    stats['yaml_examples'] += 1
                
                # 检查代码块是否为空
                if not code.strip():
                    errors.append(f"{md_file}: 发现空代码块")
    
    # 输出统计
    print("\n📊 代码示例统计:")
    print(f"  总文件数: {stats['total_files']}")
    print(f"  含代码文件: {stats['files_with_code']}")
    print(f"  Java示例: {stats['java_examples']}")
    print(f"  Scala示例: {stats['scala_examples']}")
    print(f"  Python示例: {stats['python_examples']}")
    print(f"  SQL示例: {stats['sql_examples']}")
    print(f"  YAML示例: {stats['yaml_examples']}")
    
    if errors:
        print("\n⚠️  发现的问题:")
        for error in errors[:20]:  # 只显示前20个
            print(f"  - {error}")
        if len(errors) > 20:
            print(f"  ...还有 {len(errors) - 20} 个问题")
    else:
        print("\n✅ 代码示例检查通过！")
    
    return len(errors) == 0

check_code_examples()
