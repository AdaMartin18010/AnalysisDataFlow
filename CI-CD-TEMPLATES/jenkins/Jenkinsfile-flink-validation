import re
import yaml
import sys
from pathlib import Path

def validate_flink_configs():
    """验证Flink配置文件示例"""
    flink_dir = Path('Flink')
    
    if not flink_dir.exists():
        return True
    
    errors = []
    warnings = []
    
    for md_file in flink_dir.rglob('*.md'):
        if any(part.startswith('.') for part in md_file.parts):
            continue
        
        try:
            with open(md_file, 'r', encoding='utf-8') as f:
                content = f.read()
        except:
            continue
        
        # 提取YAML配置块
        yaml_blocks = re.findall(r'```ya?ml\s*\n(.*?)```', content, re.DOTALL)
        
        for i, yaml_content in enumerate(yaml_blocks):
            try:
                # 尝试解析YAML
                config = yaml.safe_load(yaml_content)
                
                # 如果是Flink配置，检查关键字段
                if config and isinstance(config, dict):
                    # 检查是否有常见的Flink配置项
                    flink_keys = ['jobmanager', 'taskmanager', 'parallelism', 
                                  'checkpointing', 'state']
                    has_flink_config = any(k in config for k in flink_keys)
                    
                    if has_flink_config:
                        # 验证配置值
                        if 'parallelism' in config:
                            p = config['parallelism']
                            if not isinstance(p, int) or p < 1:
                                warnings.append(f"{md_file}: 并行度配置可能不合理: {p}")
                        
            except yaml.YAMLError as e:
                errors.append(f"{md_file}: YAML块 #{i+1} 解析错误: {e}")
    
    if errors:
        print("\n❌ YAML解析错误:")
        for error in errors:
            print(f"  - {error}")
    
    if warnings:
        print("\n⚠️  配置警告:")
        for warning in warnings:
            print(f"  - {warning}")
    
    if not errors and not warnings:
        print("\n✅ Flink配置验证通过！")
    
    return len(errors) == 0

success = validate_flink_configs()
sys.exit(0 if success else 1)
