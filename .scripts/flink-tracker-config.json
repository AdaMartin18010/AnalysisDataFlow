{
  "_comment": "Flink Release Tracker 配置文件",
  "version": "1.0.0",
  "check_interval_hours": 24,
  "notification_channels": ["file"],
  "target_versions": ["2.4.0", "2.5.0", "3.0.0"],
  "email": {
    "enabled": false,
    "smtp_server": "",
    "smtp_port": 587,
    "username": "",
    "password": "",
    "to_addresses": [],
    "subject_prefix": "[Flink Release Tracker]"
  },
  "slack": {
    "enabled": false,
    "webhook_url": "",
    "channel": "#flink-releases",
    "username": "Flink Release Bot"
  },
  "webhook": {
    "enabled": false,
    "url": "",
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "prospective_doc_scan": {
    "enabled": true,
    "directories": [
      "Flink/roadmap",
      "Flink/08-roadmap"
    ],
    "patterns": [
      "前瞻",
      "preview",
      "Preview",
      "planned",
      "upcoming",
      "status=preview"
    ]
  },
  "api_tracking": {
    "enabled": true,
    "track_sql_api": true,
    "track_config_changes": true,
    "track_maven_deps": true
  },
  "reporting": {
    "generate_markdown": true,
    "update_project_tracking": true,
    "history_limit": 100
  }
}
