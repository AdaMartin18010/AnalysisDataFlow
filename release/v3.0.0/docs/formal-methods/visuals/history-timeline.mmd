%% 形式化方法历史发展时间线 - Mermaid甘特图
%% 使用方法: 在支持Mermaid的编辑器中查看，或导出为图片

gantt
    title 形式化方法历史发展时间线 (1930s - 2020s)
    dateFormat YYYY
    axisFormat %Y
    
    section 1930s 计算理论
    λ演算 (Church)              :milestone, 1936, 0d
    图灵机 (Turing)             :milestone, 1936, 0d
    Church-Turing论题           :milestone, 1936, 0d
    
    section 1940s 逻辑基础
    信息论 (Shannon)            :milestone, 1948, 0d
    博弈论基础                  :milestone, 1944, 0d
    神经网络逻辑                :milestone, 1943, 0d
    
    section 1950s 编程萌芽
    FORTRAN                     :milestone, 1957, 0d
    LISP                        :milestone, 1958, 0d
    ALGOL                       :milestone, 1958, 0d
    BNF文法                     :milestone, 1959, 0d
    
    section 1960s 形式语义学
    操作语义学 (Landin)         :milestone, 1964, 0d
    霍尔逻辑 (Hoare)            :milestone, 1969, 0d
    指称语义学 (Scott)          :milestone, 1969, 0d
    面向对象起源 (Simula)       :milestone, 1967, 0d
    
    section 1970s 并发理论
    谓词变换器 (Dijkstra)       :milestone, 1974, 0d
    Petri网理论                 :milestone, 1976, 0d
    逻辑时钟 (Lamport)          :milestone, 1978, 0d
    CSP (Hoare)                 :milestone, 1978, 0d
    CCS (Milner)                :milestone, 1980, 0d
    
    section 1980s 类型革命
    关系参数性 (Reynolds)       :milestone, 1983, 0d
    LF逻辑框架                  :milestone, 1984, 0d
    线性逻辑 (Girard)           :milestone, 1987, 0d
    Liskov替换原则              :milestone, 1987, 0d
    π演算 (Milner)              :milestone, 1987, 0d
    归纳类型 (CoC)              :milestone, 1988, 0d
    
    section 1990s 模型检测
    模型检测理论                :milestone, 1990, 0d
    Coq系统                     :milestone, 1992, 0d
    局部类型推断                :milestone, 1994, 0d
    抽象解释 (Cousot)           :milestone, 1997, 0d
    SPIN工具                    :milestone, 1996, 0d
    
    section 2000s 现代验证
    分离逻辑 (Reynolds)         :milestone, 2000, 0d
    依赖类型 (Epigram/Agda)     :milestone, 2004, 0d
    F*验证框架                  :milestone, 2005, 0d
    CompCert编译器              :milestone, 2010, 0d
    Iris项目启动                :milestone, 2009, 0d
    
    section 2010s 证明助手
    四色定理形式化              :milestone, 2012, 0d
    同伦类型理论 (HoTT)         :milestone, 2013, 0d
    Lean证明助手                :milestone, 2013, 0d
    seL4内核验证                :milestone, 2014, 0d
    Isabelle Archive            :milestone, 2017, 0d
    
    section 2020s AI时代
    Lean 4发布                  :milestone, 2021, 0d
    ML证明搜索                  :milestone, 2022, 0d
    LLM辅助形式化               :milestone, 2023, 0d
    量子程序验证                :milestone, 2024, 0d
    自动形式化                  :milestone, 2025, 0d
