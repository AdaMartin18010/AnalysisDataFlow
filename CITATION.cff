# Citation File Format for AnalysisDataFlow
# Version: 1.2.0
# https://citation-file-format.github.io/

cff-version: 1.2.0
message: "If you use this software or documentation in your research, please cite it as below."
type: software
title: "AnalysisDataFlow: Formal Theory and Engineering Practice of Stream Computing"
abstract: >
  A comprehensive knowledge base for stream computing theory, hierarchy, 
  engineering practice, and business modeling. This project provides 
  rigorous, complete, and navigable documentation for academic research, 
  industrial engineering, and technology selection in the field of 
  stream processing and dataflow systems.
authors:
  - family-names: "Ma"
    given-names: "Lu"
    affiliation: "Independent Researcher"
    orcid: "https://orcid.org/0000-0000-0000-0000"  # TODO: Replace with actual ORCID
repository-code: "https://github.com/luyanfeng/AnalysisDataFlow"
url: "https://github.com/luyanfeng/AnalysisDataFlow"
license: Apache-2.0
version: 5.0.0
date-released: 2026-04-10

# Keywords for discoverability
keywords:
  - stream processing
  - dataflow model
  - formal methods
  - distributed systems
  - Apache Flink
  - concurrency theory
  - process calculus
  - actor model
  - verification
  - stream computing

# TODO: Add DOI after Zenodo registration
# doi: 10.5281/zenodo.XXXXXXX

# Preferred citation format for academic papers
preferred-citation:
  type: generic
  title: "AnalysisDataFlow: A Comprehensive Knowledge Base for Stream Computing Theory and Practice"
  authors:
    - family-names: "Ma"
      given-names: "Lu"
  year: 2026
  url: "https://github.com/luyanfeng/AnalysisDataFlow"
  # TODO: Add DOI after Zenodo registration
  # doi: 10.5281/zenodo.XXXXXXX

