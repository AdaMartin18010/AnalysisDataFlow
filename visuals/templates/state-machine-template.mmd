%% 状态机模板
%% 适用于：状态流转、生命周期、业务状态
%% 使用说明：
%% 1. 定义所有状态
%% 2. 标注状态转换条件
%% 3. 使用复合状态组织

stateDiagram-v2
    %% ===== 状态定义 =====
    [*] --> 初始化: 系统启动
    
    state "运行中" as Running {
        [*] --> 空闲
        空闲 --> 处理中: 收到任务
        处理中 --> 空闲: 处理完成
        处理中 --> 暂停: 暂停请求
        暂停 --> 处理中: 恢复请求
        处理中 --> 错误: 异常发生
    }
    
    state "维护模式" as Maintenance {
        [*] --> 备份中
        备份中 --> 升级中: 备份完成
        升级中 --> 验证中: 升级完成
        验证中 --> [*]: 验证通过
    }
    
    %% ===== 状态转换 =====
    初始化 --> 运行中: 初始化成功
    初始化 --> 错误: 初始化失败
    
    运行中 --> 维护模式: 计划维护
    运行中 --> 停止: 关闭请求
    
    错误 --> 初始化: 重置
    错误 --> 停止: 无法恢复
    
    维护模式 --> 运行中: 维护完成
    维护模式 --> 停止: 维护中断
    
    停止 --> [*]: 资源清理
    
    %% ===== 状态说明 =====
    note right of Running
        正常运行状态
        可处理业务请求
    end note
    
    note left of Maintenance
        计划内维护
        不对外提供服务
    end note
