{
  "dashboard": {
    "id": null,
    "uid": "flink-iot-sensors",
    "title": "Flink IoT - Sensor Data Overview",
    "tags": ["flink", "iot", "sensors", "kafka"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": {"value": "Prometheus", "text": "Prometheus"}
        }
      ]
    },
    "annotations": {
      "list": []
    },
    "panels": [
      {
        "id": 1,
        "title": "Active Devices",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"processed_metrics\")\n  |> aggregateWindow(every: 1m, fn: count)\n  |> group()\n  |> unique(column: \"device_id\")\n  |> count(column: \"device_id\")",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 50},
                {"color": "green", "value": 80}
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 2,
        "title": "Messages/sec (Kafka)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "rate(kafka_server_brokertopicmetrics_messagesin_total{topic=\"sensor-readings\"}[1m])",
            "legendFormat": "Messages In",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "msgs",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 10},
                {"color": "green", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Average Temperature",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"processed_metrics\" and r.metric_type == \"temperature\")\n  |> mean(column: \"_value\")",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "blue", "value": null},
                {"color": "green", "value": 15},
                {"color": "yellow", "value": 30},
                {"color": "red", "value": 40}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Alert Count (5m)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"alerts\")\n  |> count()",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 20}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Temperature Trends by Location",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 4},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"processed_metrics\" and r.metric_type == \"temperature\")\n  |> aggregateWindow(every: 1m, fn: mean)\n  |> group(columns: [\"location\"])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "min": -10,
            "max": 60,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Sensor Readings by Type",
        "type": "piechart",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 4},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"processed_metrics\")\n  |> group(columns: [\"device_type\"])\n  |> count()",
            "refId": "A"
          }
        ],
        "options": {
          "pieType": "donut",
          "legend": {
            "displayMode": "list",
            "placement": "right"
          }
        }
      },
      {
        "id": 7,
        "title": "Pressure Readings Over Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"processed_metrics\" and r.metric_type == \"pressure\")\n  |> aggregateWindow(every: 1m, fn: mean)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "pressurembar",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 20
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Humidity Levels",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"processed_metrics\" and r.metric_type == \"humidity\")\n  |> aggregateWindow(every: 1m, fn: mean)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "humidity",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 30},
                {"color": "green", "value": 40},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 85}
              ]
            },
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 30
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Temperature Distribution",
        "type": "histogram",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"processed_metrics\" and r.metric_type == \"temperature\")",
            "refId": "A"
          }
        ],
        "options": {
          "bucketSize": 2
        },
        "fieldConfig": {
          "defaults": {
            "unit": "celsius"
          }
        }
      },
      {
        "id": 10,
        "title": "Device Status Overview",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"processed_metrics\")\n  |> group(columns: [\"device_id\", \"device_type\", \"location\"])\n  |> count()\n  |> limit(n: 20)",
            "refId": "A"
          }
        ]
      },
      {
        "id": 11,
        "title": "Kafka Topic Lag",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 30},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "kafka_consumergroup_lag{topic=\"sensor-readings\"}",
            "legendFormat": "{{group}} - {{partition}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1000},
                {"color": "red", "value": 10000}
              ]
            },
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Alert History",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 30},
        "datasource": {"type": "influxdb", "uid": "InfluxDB"},
        "targets": [
          {
            "query": "from(bucket: \"sensor-data\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"alerts\")\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 50)",
            "refId": "A"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
