{
  "dashboard": {
    "id": null,
    "uid": "flink-iot-monitoring",
    "title": "Flink IoT - Cluster Monitoring",
    "tags": ["flink", "iot", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "5s",
    "time": {
      "from": "now-30m",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "cluster",
          "type": "constant",
          "current": {"value": "flink-iot-demo", "text": "flink-iot-demo"}
        },
        {
          "name": "namespace",
          "type": "constant",
          "current": {"value": "default", "text": "default"}
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Annotations & Alerts",
          "datasource": {"type": "grafana", "uid": "-- Grafana --"},
          "enable": true,
          "iconColor": "red",
          "type": "dashboard"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "JobManager Uptime",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "flink_jobmanager_uptime_timeSeconds",
            "legendFormat": "Uptime",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "center",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null}
              ]
            },
            "unit": "s"
          }
        }
      },
      {
        "id": 2,
        "title": "TaskManagers Count",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "flink_jobmanager_numRegisteredTaskManagers",
            "legendFormat": "TaskManagers",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "center"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "green", "value": 2}
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "title": "Running Jobs",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "flink_jobmanager_numRunningJobs",
            "legendFormat": "Jobs",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "yellow", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Task Slots Available",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "flink_jobmanager_taskSlotsAvailable",
            "legendFormat": "Available",
            "refId": "A"
          },
          {
            "expr": "flink_jobmanager_taskSlotsTotal",
            "legendFormat": "Total",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "green", "value": 4}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "JVM Heap Memory",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "flink_jobmanager_Status_JVM_Memory_Heap_Used / 1024 / 1024",
            "legendFormat": "JobManager Used (MB)",
            "refId": "A"
          },
          {
            "expr": "flink_jobmanager_Status_JVM_Memory_Heap_Committed / 1024 / 1024",
            "legendFormat": "JobManager Committed (MB)",
            "refId": "B"
          },
          {
            "expr": "flink_taskmanager_Status_JVM_Memory_Heap_Used / 1024 / 1024",
            "legendFormat": "TaskManager Used (MB)",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "barAlignment": 0,
              "lineWidth": 1,
              "fillOpacity": 10,
              "gradientMode": "none"
            }
          }
        }
      },
      {
        "id": 6,
        "title": "JVM CPU Load",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "flink_jobmanager_Status_JVM_CPU_Load",
            "legendFormat": "JobManager CPU",
            "refId": "A"
          },
          {
            "expr": "flink_taskmanager_Status_JVM_CPU_Load",
            "legendFormat": "TaskManager CPU",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Records In/Out Per Second",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "rate(flink_taskmanager_job_task_operator_numRecordsIn[1m])",
            "legendFormat": "{{operator_name}} - In",
            "refId": "A"
          },
          {
            "expr": "rate(flink_taskmanager_job_task_operator_numRecordsOut[1m])",
            "legendFormat": "{{operator_name}} - Out",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "records-per-sec",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Checkpoint Statistics",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "flink_jobmanager_job_numberOfCompletedCheckpoints",
            "legendFormat": "Completed",
            "refId": "A"
          },
          {
            "expr": "flink_jobmanager_job_numberOfFailedCheckpoints",
            "legendFormat": "Failed",
            "refId": "B"
          },
          {
            "expr": "flink_jobmanager_job_numberOfInProgressCheckpoints",
            "legendFormat": "In Progress",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Checkpoint Duration",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "flink_jobmanager_job_lastCheckpointDuration / 1000",
            "legendFormat": "Last Checkpoint (s)",
            "refId": "A"
          },
          {
            "expr": "flink_jobmanager_job_lastCheckpointFullSize / 1024 / 1024",
            "legendFormat": "Checkpoint Size (MB)",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Back Pressure",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "flink_taskmanager_job_task_backPressuredTimeMsPerSecond / 1000 * 100",
            "legendFormat": "{{operator_name}} - {{subtask_index}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 20},
                {"color": "red", "value": 50}
              ]
            },
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Network IO",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "rate(flink_taskmanager_Status_Network_AvailableMemorySegments[1m])",
            "legendFormat": "Available Memory Segments",
            "refId": "A"
          },
          {
            "expr": "rate(flink_taskmanager_Status_Network_TotalMemorySegments[1m])",
            "legendFormat": "Total Memory Segments",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Garbage Collection",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "targets": [
          {
            "expr": "rate(flink_jobmanager_Status_JVM_Memory_GarbageCollector_G1_Young_Generation_Count[1m])",
            "legendFormat": "GC Count (Young)",
            "refId": "A"
          },
          {
            "expr": "flink_jobmanager_Status_JVM_Memory_GarbageCollector_G1_Young_Generation_Time / 1000",
            "legendFormat": "GC Time (s)",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}
